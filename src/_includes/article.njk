{% extends "layout.njk" %}

{% block title %}
    <h1>{{title}}</h1>
    {% if authors or date or ai_assisted %}
        <p class="article-meta">
            {% if authors %}
                By
                {% for author in authors %}{% if author.url %}<a href="{{ author.url }}">{{ author.name }}</a>{% else %}{{ author.name }}{% endif %}{% if not loop.last %}, {% endif %}{% endfor %}
            {% endif %}
            {% if authors and date %} · {% endif %}
            {% if date %}<time datetime="{{ date | isoDate }}">{{ date | readableDate }}</time>{% endif %}
            {% if ai_assisted %}{% if authors or date %} · {% endif %}<a href="#ai-assistance">Assisted by AI</a>{% endif %}
        </p>
    {% endif %}
{% endblock %}

{% block article_footer %}
    {% if ai_assisted %}
        <aside id="ai-assistance" class="ai-assistance">
            <p>Human authors contributed the core concepts and reviewed the article and facts. AI assisted with wordsmithing and creating illustrations.</p>
        </aside>
    {% endif %}
{% endblock %}

{% block og %}
    <meta property="og:title" content="{{title}}">
    <meta property="og:image" content="https://www.speedpatterns.com{{og_image}}">
    <meta property="og:site_name" content="Speed Patterns">
{% endblock %}